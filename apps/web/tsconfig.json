{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@foundry/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@foundry/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@foundry/database": [
        "../../packages/database/src/index.ts"
      ],
      "@foundry/database/*": [
        "../../packages/database/src/*"
      ]
    }
  },
  "include": [
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
