{
	"name": "foundry",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.30.3",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --parallel",
		"lint": "turbo run lint",
		"lint:fix": "turbo run lint -- --fix",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
		"format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"db:generate": "pnpm --filter @foundry/database prisma:generate",
		"db:migrate": "pnpm --filter @foundry/database prisma:migrate",
		"db:push": "pnpm --filter @foundry/database prisma:push",
		"db:seed": "pnpm --filter @foundry/database db:seed"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"prettier": "^3.8.1",
		"turbo": "^2.8.13"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	}
}
